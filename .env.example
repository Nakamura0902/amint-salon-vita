# Database (Render PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/amint_salon?schema=public"

# Session secret (random 32+ chars)
SESSION_SECRET="your-random-secret-here"

# Admin password hash (generate with: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)")
ADMIN_PASSWORD_HASH="$2b$10$..."

# Mail settings (Outlook/Gmail SMTP)
MAIL_HOST="smtp-mail.outlook.com"
MAIL_PORT="587"
MAIL_USER="your-email@outlook.jp"
MAIL_PASS="your-password"
MAIL_FROM="AMINT Salon Vita <your-email@outlook.jp>"
ADMIN_EMAIL="your-email@outlook.jp"

# App URL (Render domain after deploy)
NEXT_PUBLIC_APP_URL="https://amint-salon-vita.onrender.com"
