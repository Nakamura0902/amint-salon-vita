generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  service   String
  wishDate  DateTime
  wishTime  String
  message   String?
  status    Status   @default(PENDING)
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
}
